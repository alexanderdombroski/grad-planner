---
import { SignIn, UserButton } from '@clerk/astro/components'
import { majors } from '../../data/majors'
import { getDefaultTermTemplates, getPlannerState } from '../../lib/planner-db'

const { isAuthenticated, userId } = Astro.locals.auth()
const user = isAuthenticated ? await Astro.locals.currentUser() : null
const requestedMajorCode = Astro.url.searchParams.get('major')
const savedToken = Astro.url.searchParams.get('saved')

let plannerState = null
if (isAuthenticated && userId) {
	try {
		plannerState = await getPlannerState(userId, requestedMajorCode)
	} catch {
		plannerState = null
	}
}
const majorCode = plannerState?.majorCode ?? requestedMajorCode ?? ''
const majorName =
	plannerState?.majorName ?? majors.find((major) => major.code === majorCode)?.name ?? 'Selected major'
const courseGroups = plannerState?.groups ?? []
const savedTerms = plannerState?.planner?.terms ?? []
const defaultTerms = getDefaultTermTemplates()

const termCards = defaultTerms.map((template) => {
	const savedTerm = savedTerms.find((term) => term.order === template.order || term.label === template.label) ?? null
	const checkedCourseCodes = new Set(savedTerm?.courses.map((course) => course.code) ?? [])

	return {
		template,
		savedTerm,
		checkedCourseCodes,
	}
})
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Class Planning</title>
		<meta
			name="description"
			content="Select classes for each semester after choosing a major."
		/>
		<style>
			:root {
				color-scheme: dark;
				--bg: #07111f;
				--panel: rgba(15, 23, 42, 0.8);
				--panel-soft: rgba(15, 23, 42, 0.56);
				--border: rgba(148, 163, 184, 0.18);
				--text: #f8fafc;
				--muted: #94a3b8;
				--accent: #f97316;
				--accent-2: #38bdf8;
				--shadow: 0 30px 80px rgba(2, 6, 23, 0.45);
			}

			* {
				box-sizing: border-box;
			}

			html {
				min-height: 100%;
				background:
					radial-gradient(circle at top left, rgba(249, 115, 22, 0.2), transparent 30%),
					radial-gradient(circle at 85% 10%, rgba(56, 189, 248, 0.18), transparent 24%),
					linear-gradient(180deg, #07111f 0%, #050814 100%);
			}

			body {
				margin: 0;
				min-height: 100vh;
				color: var(--text);
				font-family:
					"Inter",
					"Segoe UI",
					"Helvetica Neue",
					Arial,
					sans-serif;
			}

			a {
				color: inherit;
				text-decoration: none;
			}

			.shell {
				max-width: 1280px;
				margin: 0 auto;
				padding: 24px;
			}

			.frame {
				position: relative;
				overflow: hidden;
				border-radius: 32px;
				border: 1px solid var(--border);
				background: linear-gradient(180deg, rgba(15, 23, 42, 0.85), rgba(2, 6, 23, 0.92));
				box-shadow: var(--shadow);
			}

			.topbar {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 16px;
				padding: 24px 28px 0;
			}

			.brand {
				display: flex;
				align-items: center;
				gap: 14px;
			}

			.brand-mark {
				display: grid;
				place-items: center;
				width: 46px;
				height: 46px;
				border-radius: 15px;
				background: linear-gradient(135deg, #f97316, #fb7185 60%, #38bdf8);
				font-weight: 800;
				box-shadow: 0 14px 40px rgba(249, 115, 22, 0.35);
			}

			.brand-copy {
				display: grid;
				gap: 4px;
			}

			.brand-copy strong {
				font-size: 1.06rem;
			}

			.brand-copy span {
				color: var(--muted);
				font-size: 0.92rem;
			}

			.content {
				display: grid;
				grid-template-columns: minmax(0, 1.25fr) minmax(320px, 0.75fr);
				gap: 18px;
				padding: 24px 28px 28px;
			}

			.panel {
				border-radius: 28px;
				border: 1px solid var(--border);
				background: var(--panel);
				padding: 24px;
			}

			.kicker {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				padding: 8px 12px;
				border-radius: 999px;
				background: rgba(249, 115, 22, 0.12);
				color: #fdba74;
				font-size: 0.82rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.08em;
			}

			h1 {
				margin: 18px 0 12px;
				font-size: clamp(2.2rem, 5vw, 4rem);
				line-height: 0.96;
				letter-spacing: -0.05em;
				max-width: 12ch;
			}

			.lead {
				margin: 0;
				color: var(--muted);
				font-size: 1.02rem;
				line-height: 1.7;
				max-width: 56ch;
			}

			.hero-actions {
				display: flex;
				flex-wrap: wrap;
				gap: 12px;
				margin-top: 22px;
			}

			.button {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 12px 18px;
				border-radius: 999px;
				font-weight: 700;
				border: 1px solid transparent;
			}

			.button.primary {
				background: linear-gradient(135deg, #f97316, #fb7185);
				color: white;
			}

			.button.secondary {
				border-color: var(--border);
				background: rgba(255, 255, 255, 0.03);
			}

			.major-banner {
				margin-top: 24px;
				padding: 18px;
				border-radius: 22px;
				border: 1px solid rgba(249, 115, 22, 0.24);
				background: rgba(249, 115, 22, 0.08);
			}

			.major-banner strong {
				display: block;
				font-size: 1.05rem;
				margin-bottom: 8px;
			}

			.major-banner p {
				margin: 0;
				color: var(--muted);
				line-height: 1.6;
			}

			.term-stack {
				display: grid;
				gap: 18px;
				margin-top: 24px;
			}

			.term-card {
				padding: 18px;
				border-radius: 24px;
				border: 1px solid rgba(148, 163, 184, 0.16);
				background: var(--panel-soft);
			}

			.term-card-head {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 12px;
			}

			.term-card-head strong {
				font-size: 1rem;
			}

			.badge {
				padding: 7px 10px;
				border-radius: 999px;
				background: rgba(255, 255, 255, 0.06);
				border: 1px solid rgba(148, 163, 184, 0.12);
				color: #e2e8f0;
				font-size: 0.78rem;
				font-weight: 700;
				white-space: nowrap;
			}

			.term-meta {
				display: flex;
				flex-wrap: wrap;
				gap: 10px;
				margin-top: 12px;
				color: var(--muted);
				font-size: 0.9rem;
			}

			.term-form {
				display: grid;
				gap: 16px;
				margin-top: 16px;
			}

			.term-notes {
				display: grid;
				gap: 8px;
			}

			.term-notes label {
				color: #e2e8f0;
				font-size: 0.9rem;
				font-weight: 700;
			}

			.term-notes textarea {
				width: 100%;
				min-height: 84px;
				padding: 12px 14px;
				border-radius: 18px;
				border: 1px solid rgba(148, 163, 184, 0.18);
				background: rgba(2, 6, 23, 0.55);
				color: var(--text);
				font: inherit;
				resize: vertical;
			}

			.course-groups {
				display: grid;
				gap: 14px;
			}

			.course-group {
				padding: 16px;
				border-radius: 20px;
				border: 1px solid rgba(148, 163, 184, 0.12);
				background: rgba(255, 255, 255, 0.03);
			}

			.course-group h3 {
				margin: 0 0 8px;
				font-size: 0.98rem;
			}

			.course-group p {
				margin: 0 0 12px;
				color: var(--muted);
				font-size: 0.9rem;
				line-height: 1.5;
			}

			.course-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 10px;
			}

			.course-option {
				display: block;
				cursor: pointer;
			}

			.course-option input {
				position: absolute;
				opacity: 0;
				pointer-events: none;
			}

			.course-option-card {
				display: grid;
				gap: 6px;
				padding: 12px 14px;
				border-radius: 18px;
				border: 1px solid rgba(148, 163, 184, 0.14);
				background: rgba(2, 6, 23, 0.45);
				transition:
					transform 160ms ease,
					border-color 160ms ease,
					background 160ms ease;
			}

			.course-option:hover .course-option-card {
				transform: translateY(-1px);
				border-color: rgba(249, 115, 22, 0.3);
				background: rgba(249, 115, 22, 0.08);
			}

			.course-option input:checked + .course-option-card {
				border-color: rgba(249, 115, 22, 0.55);
				background: rgba(249, 115, 22, 0.12);
				box-shadow: 0 0 0 1px rgba(249, 115, 22, 0.14);
			}

			.course-option-card strong {
				font-size: 0.96rem;
			}

			.course-option-card span {
				color: var(--muted);
				font-size: 0.88rem;
			}

			.term-actions {
				display: flex;
				flex-wrap: wrap;
				gap: 12px;
				align-items: center;
				justify-content: space-between;
			}

			.term-actions .button {
				min-width: 180px;
			}

			.sidebar {
				display: grid;
				gap: 18px;
				align-content: start;
			}

			.checklist {
				display: grid;
				gap: 12px;
				margin: 18px 0 0;
				padding: 0;
				list-style: none;
			}

			.checklist li {
				display: flex;
				align-items: center;
				gap: 10px;
				padding: 12px 14px;
				border-radius: 16px;
				border: 1px solid rgba(148, 163, 184, 0.12);
				background: rgba(255, 255, 255, 0.03);
				color: #dbeafe;
			}

			.dot {
				width: 9px;
				height: 9px;
				border-radius: 999px;
				background: linear-gradient(135deg, #f97316, #38bdf8);
				flex: 0 0 auto;
			}

			.note {
				margin: 0;
				color: var(--muted);
				line-height: 1.6;
			}

			.empty-state {
				padding: 20px;
				border-radius: 22px;
				border: 1px dashed rgba(148, 163, 184, 0.22);
				color: var(--muted);
				line-height: 1.6;
			}

			@media (max-width: 960px) {
				.content {
					grid-template-columns: 1fr;
				}
			}

			@media (max-width: 720px) {
				.shell {
					padding: 14px;
				}

				.topbar,
				.content {
					padding-left: 18px;
					padding-right: 18px;
				}
			}
		</style>
	</head>
	<body>
		<main class="shell">
			<div class="frame">
				<header class="topbar">
					<div class="brand">
						<div class="brand-mark">G</div>
						<div class="brand-copy">
							<strong>Grad Planner</strong>
							<span>Semester class planning</span>
						</div>
					</div>

					{isAuthenticated ? (
						<div class="user-chip">
							<div>
								<div style="font-size: 0.88rem; color: var(--muted);">Signed in as</div>
								<div style="font-weight: 700;">{user?.firstName || user?.fullName || 'Student'}</div>
							</div>
							<UserButton showName={false} />
						</div>
					) : (
						<a class="button secondary" href="/">Go to sign in</a>
					)}
				</header>

				{isAuthenticated ? (
					<div class="content">
						<section class="panel">
							<span class="kicker">Semester builder</span>
							<h1>{majorName}</h1>
							<p class="lead">
								Add classes to each term, save the selections, and keep building out the degree plan one semester at a time.
							</p>

							<div class="hero-actions">
								<a class="button secondary" href="/">Back to dashboard</a>
								<a class="button primary" href="#terms">Edit terms</a>
							</div>

							{savedToken ? (
								<div class="major-banner">
									<strong>Saved</strong>
									<p>
										Your last update was stored successfully. You can continue editing any term below.
									</p>
								</div>
							) : null}

							<div class="major-banner">
								<strong>Selected major: {majorCode || 'Not set'}</strong>
								<p>
									The forms below write to `student_plans`, `student_terms`, and `student_term_courses` in the database.
								</p>
							</div>

							<div class="term-stack" id="terms">
								{termCards.map(({ template, savedTerm, checkedCourseCodes }) => (
									<article class="term-card">
										<div class="term-card-head">
											<div>
												<strong>{template.label}</strong>
												<div class="term-meta">
													<span>Term order {template.order}</span>
													<span>{template.year}</span>
												</div>
											</div>
											<span class="badge">{savedTerm ? `${savedTerm.courses.length} saved` : 'New term'}</span>
										</div>

										<form class="term-form" method="post" action="/api/plans/terms">
											<input type="hidden" name="majorCode" value={majorCode} />
											<input type="hidden" name="termLabel" value={template.label} />
											<input type="hidden" name="termOrder" value={template.order} />
											<input type="hidden" name="termYear" value={template.year} />

											<div class="term-notes">
												<label for={`notes-${template.order}`}>Term notes</label>
												<textarea
													id={`notes-${template.order}`}
													name="termNotes"
													placeholder="Add a note for this semester"
												>{savedTerm?.notes ?? ''}</textarea>
											</div>

											{courseGroups.length > 0 ? (
												<div class="course-groups">
													{courseGroups.map((group) => (
														<div class="course-group">
															<h3>{group.requirementGroup}</h3>
															<p>
																{group.requirementType}
																{group.requiredCredits ? ` · ${group.requiredCredits} credits required` : ''}
															</p>

															<div class="course-grid">
																{group.courses.map((course) => (
																	<label class="course-option">
																		<input
																			type="checkbox"
																			name="courseCodes"
																			value={course.code}
																			checked={checkedCourseCodes.has(course.code)}
																		/>
																		<div class="course-option-card">
																			<strong>{course.code}</strong>
																			<span>{course.title}</span>
																			<span>{course.credits} credits</span>
																		</div>
																	</label>
																))}
															</div>
														</div>
													))}
												</div>
											) : (
												<div class="empty-state">
													No course groups are available yet. Choose a major on the home page or confirm that your plan was
													saved correctly.
												</div>
											)}

											<div class="term-actions">
												<span class="note">
													{savedTerm
														? `Last saved with ${savedTerm.courses.length} classes.`
														: 'Select the classes you want for this term and save them to the database.'}
												</span>
												<button class="button primary" type="submit">Save term</button>
											</div>
										</form>
									</article>
								))}
							</div>
						</section>

						<aside class="sidebar">
							<div class="panel">
								<span class="kicker">Flow</span>
								<h2 style="margin: 16px 0 10px; letter-spacing: -0.03em;">How it works</h2>
								<p class="note">
									Each form updates one semester at a time. The API stores the selected major, creates or updates the
									term record, and rewrites the class list for that term.
								</p>

								<ul class="checklist">
									<li><span class="dot"></span> Major saved to the active student plan</li>
									<li><span class="dot"></span> Each term persists independently</li>
									<li><span class="dot"></span> Selected classes are validated against the major</li>
								</ul>
							</div>

							<div class="panel">
								<span class="kicker">Database</span>
								<h2 style="margin: 16px 0 10px; letter-spacing: -0.03em;">Seed schema aligned</h2>
								<p class="note">
									This page matches the tables defined in `scripts/init-db.sql`, including `majors`, `student_plans`,
									`student_terms`, and `student_term_courses`.
								</p>
							</div>
						</aside>
					</div>
				) : (
					<div class="content">
						<section class="panel">
							<span class="kicker">Sign in required</span>
							<h1>Open your planner</h1>
							<p class="lead">
								Sign in to choose a major, then start adding classes for each term.
							</p>

							<div class="hero-actions">
								<a class="button primary" href="/">Return home</a>
							</div>
						</section>

						<aside class="panel">
							<div style="margin-bottom: 12px;">
								<SignIn fallbackRedirectUrl="/plan/classes" />
							</div>
						</aside>
					</div>
				)}
			</div>
		</main>
	</body>
</html>
