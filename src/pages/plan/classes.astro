---
import { majors } from '../../data/majors'

const majorCode = Astro.url.searchParams.get('major')
const selectedMajor = majors.find((major) => major.code === majorCode) ?? null
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Class Planning</title>
		<meta
			name="description"
			content="Placeholder page for semester-by-semester class planning after selecting a major."
		/>
		<style>
			:root {
				color-scheme: dark;
				--bg: #07111f;
				--panel: rgba(15, 23, 42, 0.8);
				--panel-soft: rgba(15, 23, 42, 0.56);
				--border: rgba(148, 163, 184, 0.18);
				--text: #f8fafc;
				--muted: #94a3b8;
				--accent: #f97316;
				--accent-2: #38bdf8;
				--shadow: 0 30px 80px rgba(2, 6, 23, 0.45);
			}

			* {
				box-sizing: border-box;
			}

			html {
				min-height: 100%;
				background:
					radial-gradient(circle at top left, rgba(249, 115, 22, 0.2), transparent 30%),
					radial-gradient(circle at 85% 10%, rgba(56, 189, 248, 0.18), transparent 24%),
					linear-gradient(180deg, #07111f 0%, #050814 100%);
			}

			body {
				margin: 0;
				min-height: 100vh;
				color: var(--text);
				font-family:
					"Inter",
					"Segoe UI",
					"Helvetica Neue",
					Arial,
					sans-serif;
			}

			a {
				color: inherit;
				text-decoration: none;
			}

			.shell {
				max-width: 1180px;
				margin: 0 auto;
				padding: 24px;
			}

			.frame {
				position: relative;
				overflow: hidden;
				border-radius: 32px;
				border: 1px solid var(--border);
				background: linear-gradient(180deg, rgba(15, 23, 42, 0.85), rgba(2, 6, 23, 0.92));
				box-shadow: var(--shadow);
			}

			.topbar {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 16px;
				padding: 24px 28px 0;
			}

			.brand {
				display: flex;
				align-items: center;
				gap: 14px;
			}

			.brand-mark {
				display: grid;
				place-items: center;
				width: 46px;
				height: 46px;
				border-radius: 15px;
				background: linear-gradient(135deg, #f97316, #fb7185 60%, #38bdf8);
				font-weight: 800;
				box-shadow: 0 14px 40px rgba(249, 115, 22, 0.35);
			}

			.brand-copy {
				display: grid;
				gap: 4px;
			}

			.brand-copy strong {
				font-size: 1.06rem;
			}

			.brand-copy span {
				color: var(--muted);
				font-size: 0.92rem;
			}

			.content {
				display: grid;
				grid-template-columns: minmax(0, 1.25fr) minmax(320px, 0.75fr);
				gap: 18px;
				padding: 24px 28px 28px;
			}

			.panel {
				border-radius: 28px;
				border: 1px solid var(--border);
				background: var(--panel);
				padding: 24px;
			}

			.kicker {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				padding: 8px 12px;
				border-radius: 999px;
				background: rgba(249, 115, 22, 0.12);
				color: #fdba74;
				font-size: 0.82rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.08em;
			}

			h1 {
				margin: 18px 0 12px;
				font-size: clamp(2.2rem, 5vw, 4rem);
				line-height: 0.96;
				letter-spacing: -0.05em;
				max-width: 12ch;
			}

			.lead {
				margin: 0;
				color: var(--muted);
				font-size: 1.02rem;
				line-height: 1.7;
				max-width: 56ch;
			}

			.hero-actions {
				display: flex;
				flex-wrap: wrap;
				gap: 12px;
				margin-top: 22px;
			}

			.button {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 12px 18px;
				border-radius: 999px;
				font-weight: 700;
				border: 1px solid transparent;
			}

			.button.primary {
				background: linear-gradient(135deg, #f97316, #fb7185);
				color: white;
			}

			.button.secondary {
				border-color: var(--border);
				background: rgba(255, 255, 255, 0.03);
			}

			.major-banner {
				margin-top: 24px;
				padding: 18px;
				border-radius: 22px;
				border: 1px solid rgba(249, 115, 22, 0.24);
				background: rgba(249, 115, 22, 0.08);
			}

			.major-banner strong {
				display: block;
				font-size: 1.05rem;
				margin-bottom: 8px;
			}

			.major-banner p {
				margin: 0;
				color: var(--muted);
				line-height: 1.6;
			}

			.semester-grid {
				display: grid;
				gap: 14px;
				margin-top: 24px;
			}

			.semester-card {
				padding: 18px;
				border-radius: 22px;
				border: 1px solid rgba(148, 163, 184, 0.16);
				background: var(--panel-soft);
			}

			.semester-card-head {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 12px;
			}

			.semester-card-head strong {
				font-size: 1rem;
			}

			.badge {
				padding: 7px 10px;
				border-radius: 999px;
				background: rgba(255, 255, 255, 0.06);
				border: 1px solid rgba(148, 163, 184, 0.12);
				color: #e2e8f0;
				font-size: 0.78rem;
				font-weight: 700;
			}

			.semester-card p {
				margin: 12px 0 0;
				color: var(--muted);
				line-height: 1.6;
			}

			.sidebar {
				display: grid;
				gap: 18px;
			}

			.checklist {
				display: grid;
				gap: 12px;
				margin: 18px 0 0;
				padding: 0;
				list-style: none;
			}

			.checklist li {
				display: flex;
				align-items: center;
				gap: 10px;
				padding: 12px 14px;
				border-radius: 16px;
				border: 1px solid rgba(148, 163, 184, 0.12);
				background: rgba(255, 255, 255, 0.03);
				color: #dbeafe;
			}

			.dot {
				width: 9px;
				height: 9px;
				border-radius: 999px;
				background: linear-gradient(135deg, #f97316, #38bdf8);
				flex: 0 0 auto;
			}

			.note {
				margin: 0;
				color: var(--muted);
				line-height: 1.6;
			}

			@media (max-width: 960px) {
				.content {
					grid-template-columns: 1fr;
				}
			}

			@media (max-width: 720px) {
				.shell {
					padding: 14px;
				}

				.topbar,
				.content {
					padding-left: 18px;
					padding-right: 18px;
				}
			}
		</style>
	</head>
	<body>
		<main class="shell">
			<div class="frame">
				<header class="topbar">
					<div class="brand">
						<div class="brand-mark">G</div>
						<div class="brand-copy">
							<strong>Grad Planner</strong>
							<span>Semester class planning</span>
						</div>
					</div>

					<a class="button secondary" href="/">Back to setup</a>
				</header>

				<div class="content">
					<section class="panel">
						<span class="kicker">Coming next</span>
						<h1>
							{selectedMajor ? `Build your ${selectedMajor.name} class plan` : 'Build your class plan'}
						</h1>
						<p class="lead">
							This page is the next step after major selection. It will become the semester-by-semester class picker where
							you assign courses to fall, spring, and summer terms.
						</p>

						<div class="hero-actions">
							<a class="button primary" href="/">Change major</a>
							<a class="button secondary" href="#semester-picker">Preview structure</a>
						</div>

						{selectedMajor ? (
							<div class="major-banner">
								<strong>{selectedMajor.name}</strong>
								<p>
									Selected major code: {selectedMajor.code}. The final planner will use this choice to load the right
									requirement groups and course options.
								</p>
							</div>
						) : (
							<div class="major-banner">
								<strong>No major selected</strong>
								<p>
									Return to the setup flow and choose a major first. The planner will route here once that selection is
									made.
								</p>
							</div>
						)}

						<div class="semester-grid" id="semester-picker">
							{['Fall', 'Spring', 'Summer'].map((term) => (
								<article class="semester-card">
									<div class="semester-card-head">
										<strong>{term} term</strong>
										<span class="badge">Planned</span>
									</div>
									<p>
										Placeholder for the future class picker. This will eventually list eligible courses, prerequisites,
										credit totals, and conflict checks for the selected major.
									</p>
								</article>
							))}
						</div>
					</section>

					<aside class="sidebar">
						<div class="panel">
							<span class="kicker">Flow</span>
							<h2 style="margin: 16px 0 10px; letter-spacing: -0.03em;">Onboarding sequence</h2>
							<p class="note">
								Choose a major first, then continue to the semester builder. This page is the handoff point where future
								class selection will live.
							</p>

							<ul class="checklist">
								<li><span class="dot"></span> Major selected from the seeded majors list</li>
								<li><span class="dot"></span> Semester structure prepared for course assignment</li>
								<li><span class="dot"></span> Future step: save each class to a term</li>
							</ul>
						</div>

						<div class="panel">
							<span class="kicker">Data model</span>
							<h2 style="margin: 16px 0 10px; letter-spacing: -0.03em;">Matches the seed schema</h2>
							<p class="note">
								This page is aligned with the `majors`, `student_plans`, and `student_terms` tables in
								`scripts/init-db.sql`, so the eventual save flow can use the same structure.
							</p>
						</div>
					</aside>
				</div>
			</div>
		</main>
	</body>
</html>
