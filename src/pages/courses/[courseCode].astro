---
import { getCollection, type CollectionEntry } from 'astro:content'

export const prerender = true

type CourseEntry = CollectionEntry<'courses'>

export async function getStaticPaths() {
	const courses = await getCollection('courses')

	return courses.map((course) => ({
		params: { courseCode: course.data.slug },
		props: { course },
	}))
}

const { course } = Astro.props as { course: CourseEntry }

const prerequisiteList = course.data.prerequisites
const requirementList = course.data.majorRequirements
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{course.data.courseCode} - {course.data.title}</title>
		<meta name="description" content={course.data.description} />
		<style>
			:root {
				color-scheme: dark;
				--bg: #07111f;
				--panel: rgba(15, 23, 42, 0.78);
				--panel-strong: rgba(15, 23, 42, 0.92);
				--border: rgba(148, 163, 184, 0.18);
				--text: #f8fafc;
				--muted: #94a3b8;
				--accent: #f97316;
				--accent-2: #38bdf8;
				--shadow: 0 30px 80px rgba(2, 6, 23, 0.45);
			}

			* {
				box-sizing: border-box;
			}

			html {
				min-height: 100%;
				background:
					radial-gradient(circle at top left, rgba(249, 115, 22, 0.2), transparent 30%),
					radial-gradient(circle at 86% 14%, rgba(56, 189, 248, 0.16), transparent 24%),
					linear-gradient(180deg, #07111f 0%, #050814 100%);
			}

			body {
				margin: 0;
				min-height: 100vh;
				color: var(--text);
				font-family:
					'Inter',
					'Segoe UI',
					'Helvetica Neue',
					Arial,
					sans-serif;
			}

			a {
				color: inherit;
				text-decoration: none;
			}

			.shell {
				max-width: 1280px;
				margin: 0 auto;
				padding: 24px;
			}

			.frame {
				overflow: hidden;
				border: 1px solid var(--border);
				border-radius: 32px;
				background: linear-gradient(180deg, rgba(15, 23, 42, 0.84), rgba(2, 6, 23, 0.94));
				box-shadow: var(--shadow);
			}

			.topbar {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 16px;
				padding: 24px 28px 0;
			}

			.brand {
				display: flex;
				align-items: center;
				gap: 14px;
			}

			.brand-mark {
				display: grid;
				place-items: center;
				width: 46px;
				height: 46px;
				border-radius: 15px;
				background: linear-gradient(135deg, #f97316, #fb7185 60%, #38bdf8);
				font-weight: 800;
				box-shadow: 0 14px 40px rgba(249, 115, 22, 0.35);
			}

			.brand-copy {
				display: grid;
				gap: 4px;
			}

			.brand-copy strong {
				font-size: 1.06rem;
			}

			.brand-copy span {
				color: var(--muted);
				font-size: 0.92rem;
			}

			.button {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 12px 16px;
				border-radius: 999px;
				font-weight: 700;
				border: 1px solid var(--border);
				background: rgba(255, 255, 255, 0.03);
			}

			.hero {
				display: grid;
				grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
				gap: 18px;
				padding: 24px 28px 28px;
			}

			.panel {
				border-radius: 28px;
				border: 1px solid var(--border);
				background: var(--panel);
			}

			.main-panel {
				padding: 28px;
				background:
					linear-gradient(180deg, rgba(15, 23, 42, 0.9), rgba(15, 23, 42, 0.65)),
					radial-gradient(circle at top right, rgba(249, 115, 22, 0.18), transparent 30%);
			}

			.kicker {
				display: inline-flex;
				align-items: center;
				gap: 10px;
				padding: 8px 12px;
				border-radius: 999px;
				background: rgba(249, 115, 22, 0.12);
				color: #fdba74;
				font-size: 0.84rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.08em;
			}

			h1 {
				margin: 18px 0 12px;
				font-size: clamp(2.4rem, 5vw, 4.4rem);
				line-height: 0.95;
				letter-spacing: -0.06em;
				max-width: 14ch;
			}

			.lead {
				margin: 0;
				max-width: 60ch;
				color: var(--muted);
				line-height: 1.7;
				font-size: 1.02rem;
			}

			.facts {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 12px;
				margin-top: 24px;
			}

			.fact {
				padding: 14px 16px;
				border-radius: 20px;
				border: 1px solid rgba(148, 163, 184, 0.14);
				background: rgba(2, 6, 23, 0.35);
			}

			.fact span {
				display: block;
				color: var(--muted);
				font-size: 0.82rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
			}

			.fact strong {
				display: block;
				margin-top: 6px;
				font-size: 1.05rem;
			}

			.sidebar {
				display: grid;
				gap: 18px;
			}

			.section {
				padding: 22px;
				border-radius: 24px;
				border: 1px solid var(--border);
				background: var(--panel-strong);
			}

			.section h2 {
				margin: 0 0 12px;
				font-size: 1rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: #cbd5e1;
			}

			.section p {
				margin: 0;
				color: var(--muted);
				line-height: 1.6;
			}

			.list {
				display: grid;
				gap: 12px;
				margin: 0;
				padding: 0;
				list-style: none;
			}

			.list li {
				padding: 12px 14px;
				border-radius: 18px;
				background: rgba(255, 255, 255, 0.04);
				border: 1px solid rgba(148, 163, 184, 0.1);
			}

			.list strong {
				display: block;
				margin-bottom: 4px;
			}

			.list span {
				color: var(--muted);
				line-height: 1.5;
				font-size: 0.94rem;
			}

			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 8px;
			}

			.tag {
				padding: 7px 10px;
				border-radius: 999px;
				background: rgba(255, 255, 255, 0.06);
				border: 1px solid rgba(148, 163, 184, 0.12);
				color: #e2e8f0;
				font-size: 0.78rem;
			}
		</style>
	</head>
	<body>
		<div class="shell">
			<div class="frame">
				<header class="topbar">
					<div class="brand">
						<div class="brand-mark">GP</div>
						<div class="brand-copy">
							<strong>Grad Planner</strong>
							<span>Database-backed course pages</span>
						</div>
					</div>
					<a class="button" href="/courses">Back to catalog</a>
				</header>

				<section class="hero">
					<div class="panel main-panel">
						<div class="kicker">{course.data.courseCode}</div>
						<h1>{course.data.title}</h1>
						<p class="lead">{course.data.description}</p>

						<div class="facts">
							<div class="fact">
								<span>Credits</span>
								<strong>{course.data.credits}</strong>
							</div>
							<div class="fact">
								<span>Course code</span>
								<strong>{course.data.courseCode}</strong>
							</div>
							<div class="fact">
								<span>Subject</span>
								<strong>{course.data.subjectCode}</strong>
							</div>
							<div class="fact">
								<span>Number</span>
								<strong>{course.data.courseNumber}</strong>
							</div>
						</div>
					</div>

					<div class="sidebar">
						<div class="section">
							<h2>Prerequisites</h2>
							{prerequisiteList.length ? (
								<ul class="list">
									{prerequisiteList.map((prerequisite) => (
										<li>
											<strong>{prerequisite.courseCode}</strong>
											<span>
												Minimum grade {prerequisite.minimumGrade}
												{prerequisite.notes ? ` · ${prerequisite.notes}` : ''}
											</span>
										</li>
									))}
								</ul>
							) : (
								<p>No prerequisites recorded.</p>
							)}
						</div>

						<div class="section">
							<h2>Major placement</h2>
							{requirementList.length ? (
								<div class="tags">
									{requirementList.map((requirement) => (
										<span class="tag">
											{requirement.majorCode} · {requirement.requirementGroup}
										</span>
									))}
								</div>
							) : (
								<p>No major requirement mappings recorded.</p>
							)}
						</div>
					</div>
				</section>
			</div>
		</div>
	</body>
</html>
