---
import { getCollection } from 'astro:content'

export const prerender = true

const courses = (await getCollection('courses')).sort((a, b) =>
	a.data.courseCode.localeCompare(b.data.courseCode),
)

const totalCredits = courses.reduce((sum, course) => sum + course.data.credits, 0)
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Course Catalog</title>
		<meta
			name="description"
			content="Static course catalog generated from the grad planner database."
		/>
		<style>
			:root {
				color-scheme: dark;
				--bg: #07111f;
				--panel: rgba(15, 23, 42, 0.78);
				--border: rgba(148, 163, 184, 0.18);
				--text: #f8fafc;
				--muted: #94a3b8;
				--accent: #f97316;
				--accent-2: #38bdf8;
				--shadow: 0 30px 80px rgba(2, 6, 23, 0.45);
			}

			* {
				box-sizing: border-box;
			}

			html {
				min-height: 100%;
				background:
					radial-gradient(circle at top left, rgba(249, 115, 22, 0.2), transparent 30%),
					radial-gradient(circle at 88% 10%, rgba(56, 189, 248, 0.16), transparent 24%),
					linear-gradient(180deg, #07111f 0%, #050814 100%);
			}

			body {
				margin: 0;
				min-height: 100vh;
				color: var(--text);
				font-family:
					'Inter',
					'Segoe UI',
					'Helvetica Neue',
					Arial,
					sans-serif;
			}

			a {
				color: inherit;
				text-decoration: none;
			}

			.shell {
				max-width: 1280px;
				margin: 0 auto;
				padding: 24px;
			}

			.frame {
				overflow: hidden;
				border: 1px solid var(--border);
				border-radius: 32px;
				background: linear-gradient(180deg, rgba(15, 23, 42, 0.84), rgba(2, 6, 23, 0.94));
				box-shadow: var(--shadow);
			}

			.hero {
				padding: 28px;
				border-bottom: 1px solid var(--border);
			}

			.kicker {
				display: inline-flex;
				align-items: center;
				gap: 10px;
				padding: 8px 12px;
				border-radius: 999px;
				background: rgba(249, 115, 22, 0.12);
				color: #fdba74;
				font-size: 0.84rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.08em;
			}

			h1 {
				margin: 18px 0 12px;
				font-size: clamp(2.4rem, 5vw, 4.4rem);
				line-height: 0.95;
				letter-spacing: -0.06em;
				max-width: 12ch;
			}

			.lead {
				margin: 0;
				max-width: 62ch;
				color: var(--muted);
				line-height: 1.7;
				font-size: 1.02rem;
			}

			.stats {
				display: flex;
				flex-wrap: wrap;
				gap: 12px;
				margin-top: 22px;
			}

			.stat {
				padding: 12px 14px;
				border: 1px solid var(--border);
				border-radius: 18px;
				background: rgba(15, 23, 42, 0.56);
				min-width: 160px;
			}

			.stat strong {
				display: block;
				font-size: 1.1rem;
			}

			.stat span {
				display: block;
				margin-top: 4px;
				color: var(--muted);
				font-size: 0.9rem;
			}

			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
				gap: 16px;
				padding: 24px 28px 28px;
			}

			.card {
				padding: 20px;
				border: 1px solid var(--border);
				border-radius: 24px;
				background: var(--panel);
				transition:
					transform 0.2s ease,
					border-color 0.2s ease;
			}

			.card:hover {
				transform: translateY(-2px);
				border-color: rgba(249, 115, 22, 0.38);
			}

			.card-top {
				display: flex;
				justify-content: space-between;
				gap: 12px;
				align-items: start;
			}

			.code {
				color: #fdba74;
				font-size: 0.82rem;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.08em;
			}

			.credits {
				padding: 6px 10px;
				border-radius: 999px;
				background: rgba(56, 189, 248, 0.12);
				color: #7dd3fc;
				font-size: 0.8rem;
				font-weight: 700;
			}

			h2 {
				margin: 14px 0 8px;
				font-size: 1.2rem;
			}

			.card p {
				margin: 0;
				color: var(--muted);
				line-height: 1.6;
			}

			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 8px;
				margin-top: 16px;
			}

			.tag {
				padding: 7px 10px;
				border-radius: 999px;
				background: rgba(255, 255, 255, 0.06);
				border: 1px solid rgba(148, 163, 184, 0.12);
				color: #e2e8f0;
				font-size: 0.78rem;
			}
		</style>
	</head>
	<body>
		<div class="shell">
			<div class="frame">
				<section class="hero">
					<div class="kicker">Static catalog from the database</div>
					<h1>Course catalog</h1>
					<p class="lead">
						Every course page is prerendered from database-backed content. Open a course to
						see the summary, prerequisites, and where it fits in the CS or Cyber major.
					</p>
					<div class="stats">
						<div class="stat">
							<strong>{courses.length}</strong>
							<span>Total courses</span>
						</div>
						<div class="stat">
							<strong>{totalCredits}</strong>
							<span>Credits represented</span>
						</div>
					</div>
				</section>

				<section class="grid">
					{courses.map((course) => (
						<a class="card" href={`/courses/${course.data.slug}`}>
							<div class="card-top">
								<div class="code">{course.data.courseCode}</div>
								<div class="credits">{course.data.credits} credits</div>
							</div>
							<h2>{course.data.title}</h2>
							<p>{course.data.description}</p>
							<div class="tags">
								{course.data.majorRequirements.map((requirement) => (
									<span class="tag">{requirement.majorCode}</span>
								))}
							</div>
						</a>
					))}
				</section>
			</div>
		</div>
	</body>
</html>
